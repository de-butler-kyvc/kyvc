# .env.common 영역으로 추가, 삭제하지 않는다.
APP_STORAGE_PATH=/app/storage
LOG_PATH=/app/logs
SERVICE_LOG_PATH=/app/service-logs

APP_ENV=dev
ENV=dev
LOG_LEVEL=INFO

# .env.core 고정 영역으로 추가, 삭제하지 않는다. 로컬 환경 맞도록 값만 설정 가능하다.
DB_HOST=127.0.0.1
DB_PORT=3307
LOCAL_DB_PORT=3307
DB_NAME=kyvc_core
DB_USER=kyvc_core_dev
DB_PASSWORD=kyvc_core_dev_password
MYSQL_ROOT_PASSWORD=kyvc_core_root_password

# .env.core 로컬 구동영역으로 서버에는 반영하지 않는다.
APP_NAME=kyvc-core
APP_PORT=8090

# .env.core 커스텀 영역으로 추가, 삭제 가능하다.
XRPL_NETWORK_NAME=devnet
XRPL_JSON_RPC_URL=https://s.devnet.rippletest.net:51234
XRPL_ISSUER_SEED=
ISSUER_PRIVATE_KEY_PEM_PATH=./.local-secrets/issuer-key.pem
XRPL_FAUCET_HOST=
DID_DOC_BASE_URL=http://127.0.0.1:8090
VERIFIER_CHALLENGE_TTL_SECONDS=300
ALLOW_MAINNET=0

# AI assessment provider settings
# Current core package supports structured/provider-injected assessment input.
# External OCR/LLM providers can use these env names when provider adapters are enabled.
OCR_PROVIDER=structured_payload
LLM_PROVIDER=none
LLM_MODEL=
LLM_MULTIMODAL_ENABLED=1
LLM_MULTIMODAL_MAX_PAGES=3
OWNERSHIP_THRESHOLD_PERCENT=25.0
OWNERSHIP_TOTAL_TOLERANCE_PERCENT=1.0
ASSESSMENT_SCHEMA_VERSION=kyvc-ai-assessment-schema-v1
PROMPT_VERSION=kyvc-ai-assessment-prompt-v1

# OCR Provider: Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-layout
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=

# OCR Provider: NAVER CLOVA OCR
NAVER_CLOVA_OCR_ENDPOINT=
NAVER_CLOVA_OCR_SECRET=
NAVER_CLOVA_OCR_TEMPLATE_ID=

# LLM Provider: OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=

# LLM Provider: Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
