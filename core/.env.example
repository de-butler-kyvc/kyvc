# .env.common 영역으로 추가, 삭제하지 않는다.
APP_STORAGE_PATH=/app/storage
LOG_PATH=/app/logs
SERVICE_LOG_PATH=/app/service-logs

APP_ENV=dev
ENV=dev
LOG_LEVEL=INFO

# .env.core 고정 영역으로 추가, 삭제하지 않는다. 로컬 환경 맞도록 값만 설정 가능하다.
DB_HOST=127.0.0.1
DB_PORT=3307
LOCAL_DB_PORT=3307
DB_NAME=kyvc_core
DB_USER=kyvc_core_dev
DB_PASSWORD=kyvc_core_dev_password
MYSQL_ROOT_PASSWORD=kyvc_core_root_password

# .env.core 로컬 구동영역으로 서버에는 반영하지 않는다.
APP_NAME=kyvc-core
APP_PORT=8090

# .env.core 커스텀 영역으로 추가, 삭제 가능하다.
XRPL_NETWORK_NAME=devnet
XRPL_JSON_RPC_URL=https://s.devnet.rippletest.net:51234
XRPL_ISSUER_SEED=
XRPL_FAUCET_HOST=
DID_DOC_BASE_URL=http://127.0.0.1:8090
VERIFIER_CHALLENGE_TTL_SECONDS=300
ALLOW_MAINNET=0
